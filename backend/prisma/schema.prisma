generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  password         String            @default("")
  role             String
  department       String
  avatar           String?
  profileImage     String?
  approvalSteps    ApprovalStep[]
  auditLogs        AuditEntry[]
  documents        Document[]        @relation("DocumentSender")
  documentVersions DocumentVersion[]
  signatures       SignatureItem[]
}

model Document {
  id             String            @id @default(uuid())
  title          String
  summary        String
  senderId       String
  status         String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  version        Int               @default(1)
  category       String
  fileName       String
  approvalChain  ApprovalStep[]
  auditLog       AuditEntry[]
  sender         User              @relation("DocumentSender", fields: [senderId], references: [id])
  versionHistory DocumentVersion[]
}

model ApprovalStep {
  id           String      @id @default(uuid())
  documentId   String
  approverId   String
  orderIndex   Int
  status       String
  actedAt      DateTime?
  comment      String?
  lastReminder DateTime?
  approver     User        @relation(fields: [approverId], references: [id])
  document     Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  placements   Placement[]
}

model AuditEntry {
  id         String   @id @default(uuid())
  action     String
  actorId    String
  documentId String
  timestamp  DateTime @default(now())
  details    String?
  version    Int?
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor      User     @relation(fields: [actorId], references: [id])
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  version    Int
  fileName   String
  uploadedAt DateTime @default(now())
  uploadedBy String
  uploader   User     @relation(fields: [uploadedBy], references: [id])
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model SignatureItem {
  id      String  @id @default(uuid())
  name    String
  type    String
  preview String?
  userId  String
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Placement {
  id             String       @id @default(uuid())
  approvalStepId String
  signatureId    String
  signatureImage String?      // base64 data URL of the actual signature/stamp image
  x              Float
  y              Float
  pageNumber     Int          @default(1)
  approvalStep   ApprovalStep @relation(fields: [approvalStepId], references: [id], onDelete: Cascade)
}
